from fastapi import FastAPI, HTTPException, Path, Query
from pydantic import BaseModel
from typing import List, Optional

app = FastAPI()


class Book(BaseModel):
    title: str
    genre: str
    author: str
    language: str


books = [
    {
        "id": 1,
        "title": "The Guide",
        "author": "R K Narayan",
        "genre": "Fiction",
        "language": "English"
    },
    {
        "id": 2,
        "title": "Wings of Fire",
        "author": "A P J Abdul Kalam",
        "genre": "Biography",
        "language": "English"
    }
]


@app.get('/books')
def get_books(genre: Optional[str] = Query(None, description="Filter books by genre")):
    if genre:
        filtered_books = [book for book in books if book["genre"].lower() == genre.lower()]
        return filtered_books
    return books


@app.get('/books/{book_id}')
def get_book_by_id(book_id: int = Path(..., description="The ID of the book you want to retrieve")):
    for book in books:
        if book["id"] == book_id:
            return book
    raise HTTPException(status_code=404, detail="Book not found")


@app.post('/books', status_code=201)
def create_book(book: Book):
    
    new_id = max((b["id"] for b in books), default=0) + 1

    new_book = {
        "id": new_id,
        "title": book.title,
        "author": book.author,
        "genre": book.genre,
        "language": book.language 
    }

    books.append(new_book)

    return {
        "message": "Book Added Successfully",
        "book": new_book
    }
