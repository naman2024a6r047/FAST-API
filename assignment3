from fastapi import FastAPI
from pydantic import BaseModel

app = FastAPI()



class Book(BaseModel):
    title : str
    genre : str
    author : str
    language : str


books = [
    {
        "id": 1,
        "title": "The Guide",
        "author": "R K Narayan",
        "genre": "Fiction",
        "language": "English"
    },
    {
        "id": 2,
        "title": "Wings of Fire",
        "author": "A P J Abdul Kalam",
        "genre": "Biography",
        "language": "English"
    }
]

@app.get('/books')
def home():
    # return ["Your message has been arrived"]
    return books


@app.post('/books',status_code = 201)
def create_book(book: Book):
    new_id = max((b["id"] for b in books), default = 0) + 1

    new_book = {
        "id": new_id,
        "title" :  book.title,
        "author" : book.author,
        "genre" : book.genre,
        "language" : book.language 

    }


    books.append(new_book)

    return {
        "message": "Book Added Successfully",
        "book" : new_book
    }
